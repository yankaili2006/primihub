# APSI — this is the file bazel ACTUALLY reads: WORKSPACE is a symlink to
# WORKSPACE_GITHUB, and the CI copies WORKSPACE_GITHUB.cn over WORKSPACE_GITHUB
# AFTER copying WORKSPACE.cn over WORKSPACE (which the symlink redirects into
# WORKSPACE_GITHUB), so WORKSPACE_GITHUB.cn wins. http_archive (not git_repository)
# fetches the exact commit 65b1507 (branch ci/arm64-apsi-genrule) which ships a real
# pre-expanded config.h (APSI 0.8.2, C++17) committed as a SOURCE header (force-added
# past .gitignore **/config.h). A git_repository shallow-clone here got a tree whose
# config.h is gitignored/absent -> "missing input file config.h" in version_lib.
http_archive(
    name = "mircrosoft_apsi",
    urls = ["https://github.com/primihub/APSI/archive/65b15076d95f9cfe1c1f53f2dc9f3dd43daeb724.tar.gz"],
    strip_prefix = "APSI-65b15076d95f9cfe1c1f53f2dc9f3dd43daeb724",
)

load("@mircrosoft_apsi//bazel:repositories.bzl", "apsi_dependencies")
apsi_dependencies("mircrosoft_apsi");

