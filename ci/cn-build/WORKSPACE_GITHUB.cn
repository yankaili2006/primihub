# seal primihub fork from microsoft, used by crypTFlow2 and APSI
new_git_repository(
  name = "com_github_primihub_seal_40",
  build_file = "@com_github_bazel_rules_3rdparty//:BUILD.seal",
  remote = "https://github.com/primihub/SEAL.git",
  branch = "change_submodule_resource",
  #branch = "main",
  patch_cmds = [
    "sed -i 's|gitee.com/mirrors_madler/zlib|github.com/madler/zlib|' cmake/ExternalZLIB.cmake",
    "sed -i 's|gitee.com/mirrors_microsoft/GSL|github.com/microsoft/GSL|' cmake/ExternalMSGSL.cmake",
    "sed -i 's|gitee.com/cs-beegfs/zstd|github.com/facebook/zstd|' cmake/ExternalZSTD.cmake",
  ],
)

