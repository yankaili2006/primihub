# Bazel BUILD wrapper for brave-experiments/frodo-pir (PETS'23).
#
# This file is loaded by WORKSPACE via:
#   new_git_repository(
#       name = "frodo_pir",
#       remote = "https://github.com/brave-experiments/frodo-pir.git",
#       commit = "1557396058e2bf89a5aad8fc82adccb0d7141454",
#       build_file = "@//thirdparty/pir:BUILD.frodo_pir",
#       shallow_since = "1704897297 +0100",
#   )
#
# UPSTREAM LANGUAGE INVENTORY:
#   * src/*.rs (api.rs, db.rs, errors.rs, lib.rs, utils.rs)
#       100% Rust crate `frodo-pir`. Implements the FrodoPIR algorithm
#       core (offline DB compression, online query, response decoding)
#       on top of `rand` / `serde` / `bincode`.
#   * data/
#       Test vectors and pre-generated DB fixtures used by the upstream
#       tests. Exposed as a filegroup for downstream regression tests
#       that want to lock in the same numbers the paper reports.
#   * NO C / C++ / asm sources — `find -name "*.c" -o -name "*.h"` is
#       empty. The Rust crate is the entire library.
#
# IMPLICATION FOR PRIMIHUB FRODOPIR OPERATOR (task 7.1 cc):
#   With no C surface to wrap, this BUILD file is *informational* —
#   it pins the commit and exposes the test-vector data, but the C++
#   FrodoPirOperator implementation must be a full port from the Rust
#   reference. Estimated ~800 LOC across db.rs (DB compression),
#   api.rs (Client/Server protocol), utils.rs (LWE helpers).
#
# REJECTED INTEGRATION PATHS (same logic as BUILD.simplepir):
#   * rules_rust + cxx-bridge: adds ~1 GB of Rust SDK / Cargo state to
#     every primihub build closure for a single algorithm.
#   * host-cargo genrule: unhermetic, breaks reproducible builds.
#   * Drop the algorithm: FrodoPIR remains the most communication-
#     efficient single-server PIR (paper Fig.4) so keeping it on the
#     roadmap is worth the port cost.

load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

# Empty placeholder cc_library so primihub BUILD files can still write
# `deps = ["@frodo_pir//:frodo_pir_native"]` and have bazel resolve the
# target. Compiles to nothing — the algorithm lives in the primihub
# C++ port that will materialize when task 7.1 cc lands.
cc_library(
    name = "frodo_pir_native",
    srcs = [],
)

# Test-vector fixtures used by frodo-pir's own Rust tests. Exposed as a
# data target so the C++ port can lock onto identical reference
# answers during correctness tests.
filegroup(
    name = "test_data",
    srcs = glob(["data/**"], allow_empty = True),
)
